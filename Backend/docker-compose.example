
services:
  db:
    image: postgres:14
    container_name: postgres_container
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}" ]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - backend

  flask-app:
    build:
      context: .
    container_name: flask_app_container
    env_file:
      - .env
    environment:
      FLASK_SECRET_KEY: ${FLASK_SECRET_KEY}
      DATABASE_URL: ${DATABASE_URL}
      FIREBASE_API_KEY: ${FIREBASE_API_KEY}
      OPENAI_API_KEY: ${OPENAI_API_KEY}
      SMTP_HOST: ${SMTP_HOST}
      SMTP_PORT: ${SMTP_PORT}
      SMTP_EMAIL: ${SMTP_EMAIL}
      SMTP_PASSWORD: ${SMTP_PASSWORD}
      APP_NAME: ${APP_NAME}
      FIREBASE_CREDENTIALS_PATH : ${FIREBASE_CREDENTIALS_PATH}
      FLASK_DEBUG: "0"  #  Debugging deaktivieren für Produktion
    depends_on:
      db:
        condition: service_healthy  #  Flask startet erst, wenn die DB bereit ist
    expose:
      - "5000"  # Flask bleibt innerhalb des Netzwerks sichtbar, aber nicht für die
    volumes:
      - sentence_transformer_cache:/root/.cache/torch/sentence_transformers/
    command: >
      sh -c "flask db upgrade &&
             gunicorn -b 0.0.0.0:5000 --timeout 120 main:app"
    networks:
      - backend

  nginx:
    image: nginx:latest
    container_name: nginx_proxy
    restart: always
    ports:
      - "80:80"  # Nginx wird auf Port 80 erreichbar sein
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro


    depends_on:
      - flask-app  # Nginx startet erst, wenn Flask bereit ist
    networks:
      - backend


volumes:
  postgres_data:  #  Datenbankvolumen für persistente Speicherung
  sentence_transformer_cache:

networks:
  backend:
